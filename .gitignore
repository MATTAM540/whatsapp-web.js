# Root gitignore
.agents/

# whatsapp-dashboard dependencies
whatsapp-dashboard/node_modules/
whatsapp-dashboard/.pnp
whatsapp-dashboard/.pnp.*
whatsapp-dashboard/.yarn/*
!whatsapp-dashboard/.yarn/patches
!whatsapp-dashboard/.yarn/plugins
!whatsapp-dashboard/.yarn/releases
!whatsapp-dashboard/.yarn/versions

# whatsapp-dashboard testing
whatsapp-dashboard/coverage

# whatsapp-dashboard next.js
whatsapp-dashboard/.next/
whatsapp-dashboard/.wwebjs_cache/
whatsapp-dashboard/out/

# whatsapp-dashboard production
whatsapp-dashboard/build

# whatsapp-dashboard misc
whatsapp-dashboard/.DS_Store
whatsapp-dashboard/*.pem

# whatsapp-dashboard debug
whatsapp-dashboard/npm-debug.log*
whatsapp-dashboard/yarn-debug.log*
whatsapp-dashboard/yarn-error.log*
whatsapp-dashboard/.pnpm-debug.log*

# whatsapp-dashboard env files
whatsapp-dashboard/.env*
!whatsapp-dashboard/.env.example

# whatsapp-dashboard vercel
whatsapp-dashboard/.vercel

# whatsapp-dashboard typescript
whatsapp-dashboard/*.tsbuildinfo
whatsapp-dashboard/next-env.d.ts

# whatsapp-dashboard specific ignores
whatsapp-dashboard/src/generated/prisma
whatsapp-dashboard/.wwebjs_auth/
whatsapp-dashboard/prisma/dev.db
whatsapp-dashboard/prisma/dev.db-journal
whatsapp-dashboard/dev.db
whatsapp-dashboard/dev.db-journal
whatsapp-dashboard/.vscode/
whatsapp-dashboard/.idea/
whatsapp-dashboard/temp/
whatsapp-dashboard/tmp/
whatsapp-dashboard/*.log

# Project level misc
.DS_Store
node_modules/
dist/
build/
.vscode/
.idea/
.wwebjs_cache/
.wwebjs_auth/
.cache/
.turbo/
.vercel/
.next/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.env*
!whatsapp-dashboard/.env.example
.node_repl_history
tmp/
temp/
whatsapp-dashboard/schema.sql
