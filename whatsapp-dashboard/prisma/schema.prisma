generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model ScheduledMessage {
  id          String   @id @default(uuid())
  toPhone     String
  text        String
  sendAt      DateTime
  status      String   @default("PENDING") // PENDING, SENT, FAILED
  createdAt   DateTime @default(now())
}

model AutoReplyRule {
  id          String   @id @default(uuid())
  triggerType String   // EXACT_MATCH, CONTAINS, ALWAYS
  keyword     String?  // nullable if ALWAYS
  replyText   String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model AppSetting {
  key         String   @id
  value       String
  updatedAt   DateTime @updatedAt
}
