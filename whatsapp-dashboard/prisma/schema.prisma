generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model ScheduledMessage {
  id          String   @id @default(uuid())
  toPhone     String
  text        String
  sendAt      DateTime
  status      String   @default("PENDING") // PENDING, SENT, FAILED
  minDelay    Int     @default(2)
  maxDelay    Int     @default(5)
  batchId     String?
  createdAt   DateTime @default(now())
}

model AutoReplyRule {
  id          String   @id @default(uuid())
  triggerType String   // EXACT_MATCH, CONTAINS, ALWAYS
  keyword     String?  // nullable if ALWAYS
  replyText   String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model AppSetting {
  key         String   @id
  value       String
  updatedAt   DateTime @updatedAt
}

model Contact {
  id          String   @id @default(uuid())
  name        String
  phoneNumber String   @unique
  createdAt   DateTime @default(now())
}
